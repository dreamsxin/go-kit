package {{.Service.ServiceName | lower}}

import (
	"context"
	"errors"
	"fmt"
	"log"
	"time"

	idl "{{if eq .Source "proto"}}{{.ImportPath}}/pb{{else}}{{.ImportPath}}{{end}}"
)

// {{.Service.ServiceName}} defines the business contract.
type {{.Service.ServiceName}} interface {
{{range .IRService.Methods}}
	// {{.Name}}{{if .Description}} - {{.Description}}{{end}}
	{{.Name}}(ctx context.Context, req idl.{{.InputName}}) (idl.{{.OutputName}}, error)
{{end}}
}

// ServiceConfig controls generated service behavior.
type ServiceConfig struct {
	LogLevel      string        `json:"log_level"`
	Timeout       time.Duration `json:"timeout"`
	EnableLogging bool          `json:"enable_logging"`
	EnableMetrics bool          `json:"enable_metrics"`
}

var defaultConfig = &ServiceConfig{
	LogLevel:      "info",
	Timeout:       30 * time.Second,
	EnableLogging: true,
}

{{if .WithModel}}
// NewService creates a service without repository dependencies.
func NewService(cfg *ServiceConfig) {{.Service.ServiceName}} {
	return NewServiceWithRepo(cfg, GeneratedRepos{})
}

// NewServiceWithRepo creates a service with repository dependencies.
func NewServiceWithRepo(cfg *ServiceConfig, repos GeneratedRepos) {{.Service.ServiceName}} {
	if cfg == nil {
		cfg = defaultConfig
	}
	return newServiceImpl(cfg, repos)
}

func newServiceImpl(cfg *ServiceConfig, repos GeneratedRepos) {{.Service.ServiceName}} {
	var svc {{.Service.ServiceName}} = &serviceImpl{
		config: cfg,
		logger: log.Default(),
		repos:  repos,
	}

	if cfg.EnableLogging {
		svc = LoggingMiddleware(log.Default())(svc)
	}
	if cfg.EnableMetrics {
		svc = MetricsMiddleware()(svc)
	}

	return svc
}
{{else}}
// NewService creates a service instance.
func NewService(cfg *ServiceConfig) {{.Service.ServiceName}} {
	if cfg == nil {
		cfg = defaultConfig
	}
	return newServiceImpl(cfg)
}

func newServiceImpl(cfg *ServiceConfig) {{.Service.ServiceName}} {
	var svc {{.Service.ServiceName}} = &serviceImpl{
		config: cfg,
		logger: log.Default(),
	}

	if cfg.EnableLogging {
		svc = LoggingMiddleware(log.Default())(svc)
	}
	if cfg.EnableMetrics {
		svc = MetricsMiddleware()(svc)
	}

	return svc
}
{{end}}

type serviceImpl struct {
	config *ServiceConfig
	logger *log.Logger
{{- if .WithModel}}
	repos  GeneratedRepos
{{- end}}
}

{{range .IRService.Methods}}
func (s *serviceImpl) {{.Name}}(ctx context.Context, req idl.{{.InputName}}) (idl.{{.OutputName}}, error) {
	_ = req
	return idl.{{.OutputName}}{}, errors.New("{{.Name}}: not implemented")
}
{{end}}

func errorf(format string, args ...any) error {
	return fmt.Errorf(format, args...)
}

type ServiceMiddleware func({{.Service.ServiceName}}) {{.Service.ServiceName}}

func LoggingMiddleware(logger *log.Logger) ServiceMiddleware {
	return func(next {{.Service.ServiceName}}) {{.Service.ServiceName}} {
		return &loggingMiddleware{next: next, logger: logger}
	}
}

type loggingMiddleware struct {
	next   {{.Service.ServiceName}}
	logger *log.Logger
}

{{range .IRService.Methods}}
func (m *loggingMiddleware) {{.Name}}(ctx context.Context, req idl.{{.InputName}}) (resp idl.{{.OutputName}}, err error) {
	start := time.Now()
	defer func() {
		if err != nil {
			m.logger.Printf("[{{$.Service.ServiceName}}] {{.Name}} err=%v elapsed=%v", err, time.Since(start))
		} else {
			m.logger.Printf("[{{$.Service.ServiceName}}] {{.Name}} elapsed=%v", time.Since(start))
		}
	}()
	return m.next.{{.Name}}(ctx, req)
}
{{end}}

func MetricsMiddleware() ServiceMiddleware {
	return func(next {{.Service.ServiceName}}) {{.Service.ServiceName}} {
		return &metricsMiddleware{next: next}
	}
}

type metricsMiddleware struct {
	next {{.Service.ServiceName}}
}

{{range .IRService.Methods}}
func (m *metricsMiddleware) {{.Name}}(ctx context.Context, req idl.{{.InputName}}) (idl.{{.OutputName}}, error) {
	return m.next.{{.Name}}(ctx, req)
}
{{end}}
