	case "consul":
		loaded, err = loadRemoteFromConsul(cfg)
	case "":
		err = fmt.Errorf("config: remote enabled but provider is empty")
	default:
		err = fmt.Errorf("config: unsupported remote provider %q", cfg.Remote.Provider)
	}

	if err != nil {
		if cfg.Remote.FallbackToLocal {
			return cfg, nil
		}
		return nil, err
	}

	return loaded, nil
}

