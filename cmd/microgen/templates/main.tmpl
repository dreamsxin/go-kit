// @description    {{if gt (len .Services) 1}}Microservice API{{else if gt (len .Services) 0}}{{if (index .Services 0).Description}}{{(index .Services 0).Description}}{{else}}{{(index .Services 0).ServiceName}} microservice API{{end}}{{else}}Microservice API{{end}}
