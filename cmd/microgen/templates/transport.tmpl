package {{.Service.ServiceName | lower}}

import (
	"context"
	"encoding/json"
	"net/http"

	"github.com/dreamsxin/go-kit/transport/http/server"
	idl "{{if eq .Source "proto"}}{{.ImportPath}}/pb{{else}}{{.ImportPath}}{{end}}"
	genendpoint "{{.ImportPath}}/endpoint/{{.Service.ServiceName | lower}}"
)

// NewHTTPHandler 返回服务的 HTTP Handler
func NewHTTPHandler(endpoints genendpoint.{{.Service.ServiceName}}Endpoints) http.Handler {
	m := http.NewServeMux()

{{range .Service.Methods}}
	// {{.HTTPMethod | upper}} {{.Route}}
	m.Handle("{{.HTTPMethod | upper}} {{.Route}}", server.NewJSONEndpoint[idl.{{.Input}}](
		endpoints.{{.Name}}Endpoint,
		server.ServerErrorEncoder(server.JSONErrorEncoder),
	))
{{end}}

	return m
}

{{range .Service.Methods}}
// decode{{.Name}}Request 默认使用 NewJSONServer 的自动解码。
// 如果需要自定义解码逻辑（如从 URL 参数提取），请在此实现。
//
// @Summary      {{.Summary}}
// @Description  {{if .Doc}}{{.Doc}}{{else}}{{.Name}} microservice endpoint{{end}}
// @Tags         {{$.Service.ServiceName}}
{{- if eq .HTTPMethod "get"}}
// @Accept       json
// @Produce      json
// @Param        request  query     idl.{{.Input}}  true  "{{.Name}} request"
{{- else}}
// @Accept       json
// @Produce      json
// @Param        request  body      idl.{{.Input}}  true  "{{.Name}} request"
{{- end}}
// @Success      200      {object}  idl.{{.Output}}
// @Failure      400      {object}  string
// @Failure      500      {object}  string
// @Router       {{$.RoutePrefix}}{{.Route}} [{{.HTTPMethod | lower}}]
func decode{{.Name}}Request(_ context.Context, r *http.Request) (any, error) {
	var req idl.{{.Input}}
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		return nil, err
	}
	return req, nil
}

// encode{{.Name}}Response 默认使用 NewJSONServer 的自动编码。
func encode{{.Name}}Response(ctx context.Context, w http.ResponseWriter, response any) error {
	return json.NewEncoder(w).Encode(response)
}
{{end}}
