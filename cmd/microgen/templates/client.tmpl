package main

import (
	"bytes"
	"context"
	"encoding/json"
	"flag"
	"fmt"
	"log"
	"net/http"
	"time"

	idl "{{if eq .Source "proto"}}{{.ImportPath}}/pb{{else}}{{.ImportPath}}{{end}}"
{{- if .WithGRPC}}
	genTransport "{{.ImportPath}}/transport/{{.Service.ServiceName | lower}}"
	"google.golang.org/grpc"
	"google.golang.org/grpc/credentials/insecure"
{{- end}}
)

// ─────────────────────────── HTTP Client ───────────────────────────

// {{.Service.ServiceName}}HTTPClient {{.Service.ServiceName}} HTTP 客户端
type {{.Service.ServiceName}}HTTPClient struct {
	baseURL    string
	httpClient *http.Client
}

// New{{.Service.ServiceName}}HTTPClient 创建 HTTP 客户端，baseURL 如 "http://localhost:8080"
func New{{.Service.ServiceName}}HTTPClient(baseURL string) *{{.Service.ServiceName}}HTTPClient {
	return &{{.Service.ServiceName}}HTTPClient{
		baseURL:    baseURL,
		httpClient: &http.Client{Timeout: 30 * time.Second},
	}
}

func (c *{{.Service.ServiceName}}HTTPClient) do(ctx context.Context, path string, req, resp interface{}) error {
	body, err := json.Marshal(req)
	if err != nil {
		return fmt.Errorf("marshal: %w", err)
	}
	httpReq, err := http.NewRequestWithContext(ctx, "POST", c.baseURL+path, bytes.NewBuffer(body))
	if err != nil {
		return fmt.Errorf("new request: %w", err)
	}
	httpReq.Header.Set("Content-Type", "application/json")
	r, err := c.httpClient.Do(httpReq)
	if err != nil {
		return fmt.Errorf("send: %w", err)
	}
	defer r.Body.Close()
	if r.StatusCode != http.StatusOK {
		return fmt.Errorf("status %d", r.StatusCode)
	}
	return json.NewDecoder(r.Body).Decode(resp)
}

{{range .Service.Methods}}
// {{.Name}} 通过 HTTP 调用 {{.Name}}
func (c *{{$.Service.ServiceName}}HTTPClient) {{.Name}}(ctx context.Context, req idl.{{.Input}}) (idl.{{.Output}}, error) {
	var resp idl.{{.Output}}
	return resp, c.do(ctx, "{{$.RoutePrefix}}{{.Route}}", req, &resp)
}
{{end}}

{{- if .WithGRPC}}
// ─────────────────────────── gRPC Client ───────────────────────────

// {{.Service.ServiceName}}GRPCClient gRPC 客户端
type {{.Service.ServiceName}}GRPCClient struct {
	conn *grpc.ClientConn
{{range .Service.Methods}}	{{.Name | lower}} func(ctx context.Context, request interface{}) (interface{}, error)
{{end}}
}

// New{{.Service.ServiceName}}GRPCClient 创建 gRPC 客户端，addr 格式如 "localhost:8081"
func New{{.Service.ServiceName}}GRPCClient(addr string, opts ...grpc.DialOption) (*{{.Service.ServiceName}}GRPCClient, error) {
	if len(opts) == 0 {
		opts = []grpc.DialOption{
			grpc.WithTransportCredentials(insecure.NewCredentials()),
			grpc.WithTimeout(5 * time.Second), //nolint:staticcheck
		}
	}
	conn, err := grpc.Dial(addr, opts...) //nolint:staticcheck
	if err != nil {
		return nil, fmt.Errorf("grpc dial %s: %w", addr, err)
	}
	return &{{.Service.ServiceName}}GRPCClient{
		conn: conn,
{{range .Service.Methods}}		{{.Name | lower}}: genTransport.NewGRPC{{.Name}}Client(conn),
{{end}}
	}, nil
}

// Close 关闭 gRPC 连接
func (c *{{.Service.ServiceName}}GRPCClient) Close() error {
	return c.conn.Close()
}

{{range .Service.Methods}}
// {{.Name}} 通过 gRPC 调用 {{.Name}}
func (c *{{$.Service.ServiceName}}GRPCClient) {{.Name}}(ctx context.Context, req idl.{{.Input}}) (idl.{{.Output}}, error) {
	resp, err := c.{{.Name | lower}}(ctx, req)
	if err != nil {
		return idl.{{.Output}}{}, err
	}
	return resp.(idl.{{.Output}}), nil
}
{{end}}
{{- end}}

// ─────────────────────────── 通用接口 ───────────────────────────

// {{.Service.ServiceName}}Client 统一客户端接口（HTTP 和 gRPC 均实现该接口）
type {{.Service.ServiceName}}Client interface {
{{range .Service.Methods}}	{{.Name}}(ctx context.Context, req idl.{{.Input}}) (idl.{{.Output}}, error)
{{end}}
}

// ─────────────────────────── Demo logic ───────────────────────────

func runDemo(client {{.Service.ServiceName}}Client, logger *log.Logger) {
	ctx := context.Background()
{{range .Service.Methods}}
	logger.Println(">>> {{.Name}}")
	{{.Name | lower}}Resp, err := client.{{.Name}}(ctx, idl.{{.Input}}{})
	if err != nil {
		logger.Printf("    FAIL: %v", err)
	} else {
		logger.Printf("    OK  : %+v", {{.Name | lower}}Resp)
	}
{{end}}
}

// ─────────────────────────── main ───────────────────────────

func main() {
	var (
{{- if .WithGRPC}}
		mode     = flag.String("mode", "grpc", "client mode: http or grpc")
		grpcAddr = flag.String("grpc.addr", "localhost:8081", "gRPC server address (mode=grpc)")
{{- else}}
		mode     = flag.String("mode", "http", "client mode: http")
{{- end}}
		httpAddr = flag.String("http.addr", "http://localhost:8080", "HTTP server address (mode=http)")
	)
	flag.Parse()

	logger := log.New(log.Writer(), "[demo] ", log.LstdFlags)

	switch *mode {
{{- if .WithGRPC}}
	case "grpc":
		logger.Printf("=== {{.Service.ServiceName}} gRPC Client Demo  addr=%s ===", *grpcAddr)
		client, err := New{{.Service.ServiceName}}GRPCClient(*grpcAddr)
		if err != nil {
			logger.Fatalf("FATAL: dial grpc: %v", err)
		}
		defer client.Close()
		runDemo(client, logger)
{{- end}}
	case "http":
		logger.Printf("=== {{.Service.ServiceName}} HTTP Client Demo  addr=%s ===", *httpAddr)
		runDemo(New{{.Service.ServiceName}}HTTPClient(*httpAddr), logger)
	default:
		logger.Fatalf("unknown mode %q{{if .WithGRPC}}, use -mode=grpc or -mode=http{{else}}, use -mode=http{{end}}", *mode)
	}

	logger.Println("=== Demo completed ===")
}
