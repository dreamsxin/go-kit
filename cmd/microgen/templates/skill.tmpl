package skill

import (
	"encoding/json"
	"net/http"
)

// OpenAI Tool format
type OpenAITool struct {
	Type     string           `json:"type"`
	Function OpenAIFunction   `json:"function"`
}

type OpenAIFunction struct {
	Name        string      `json:"name"`
	Description string      `json:"description,omitempty"`
	Parameters  interface{} `json:"parameters,omitempty"`
}

// MCP Tool format
type MCPTool struct {
	Name        string      `json:"name"`
	Description string      `json:"description,omitempty"`
	InputSchema interface{} `json:"inputSchema,omitempty"`
}

func getOpenAITools() []OpenAITool {
	return []OpenAITool{
		{{- range .Services }}
		{{- range .Methods }}
		{
			Type: "function",
			Function: OpenAIFunction{
				Name:        "{{ .Name }}",
				Description: "{{ .Summary }}",
				Parameters: map[string]interface{}{
					"type": "object",
					"properties": map[string]interface{}{
						{{- $input := .Input -}}
						{{- range $.Models }}{{ if eq .Name $input -}}
						{{- range .Fields }}
						"{{ .JSONTag }}": map[string]interface{}{
							"type": "{{ if or (eq .Type "int32") (eq .Type "int64") (eq .Type "uint32") (eq .Type "uint64") }}integer{{ else if or (eq .Type "float32") (eq .Type "float64") }}number{{ else if eq .Type "bool" }}boolean{{ else if hasPrefix .Type "[]" }}array{{ else }}string{{ end }}",
							"description": "{{ .Comment }}",
						},
						{{- end }}
						{{- end }}{{ end }}
					},
					"required": []string{
						{{- $input := .Input -}}
						{{- range $.Models }}{{ if eq .Name $input -}}
						{{- range .Fields }}{{ if or .IsNotNull (not (hasPrefix .Type "*")) }}
						"{{ .JSONTag }}",
						{{- end }}{{ end }}
						{{- end }}{{ end }}
					},
				},
			},
		},
		{{- end }}
		{{- end }}
	}
}

func getMCPTools() []MCPTool {
	return []MCPTool{
		{{- range .Services }}
		{{- range .Methods }}
		{
			Name:        "{{ .Name }}",
			Description: "{{ .Summary }}",
			InputSchema: map[string]interface{}{
				"type": "object",
				"properties": map[string]interface{}{
					{{- $input := .Input -}}
					{{- range $.Models }}{{ if eq .Name $input -}}
					{{- range .Fields }}
					"{{ .JSONTag }}": map[string]interface{}{
						"type": "{{ if or (eq .Type "int32") (eq .Type "int64") (eq .Type "uint32") (eq .Type "uint64") }}integer{{ else if or (eq .Type "float32") (eq .Type "float64") }}number{{ else if eq .Type "bool" }}boolean{{ else if hasPrefix .Type "[]" }}array{{ else }}string{{ end }}",
						"description": "{{ .Comment }}",
					},
					{{- end }}
					{{- end }}{{ end }}
				},
				"required": []string{
					{{- $input := .Input -}}
					{{- range $.Models }}{{ if eq .Name $input -}}
					{{- range .Fields }}{{ if or .IsNotNull (not (hasPrefix .Type "*")) }}
					"{{ .JSONTag }}",
					{{- end }}{{ end }}
					{{- end }}{{ end }}
				},
			},
		},
		{{- end }}
		{{- end }}
	}
}

// Handler returns the AI skill definition in JSON format.
// Supports both OpenAI (via ?format=openai) and MCP (via ?format=mcp) styles.
func Handler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	format := r.URL.Query().Get("format")
	if format == "mcp" {
		json.NewEncoder(w).Encode(map[string]interface{}{
			"tools": getMCPTools(),
		})
		return
	}
	json.NewEncoder(w).Encode(map[string]interface{}{
		"tools": getOpenAITools(),
	})
}
