package {{.Service.ServiceName | lower}}

import (
{{- if .UnaryMethods}}
	"context"
	"encoding/json"
{{- end}}
	"net/http"

{{- if .HasGETMethods}}
	transporthttp "github.com/dreamsxin/go-kit/v2/transport/http"
{{- end}}
{{- if .UnaryMethods}}
	"github.com/dreamsxin/go-kit/v2/transport/http/server"
	idl "{{if eq .Source "proto"}}{{.ImportPath}}/pb{{else}}{{.ImportPath}}{{end}}"
{{- end}}
	genendpoint "{{.ImportPath}}/endpoint/{{.Service.ServiceName | lower}}"
)

// NewHTTPHandler returns the generated HTTP handler set.
func NewHTTPHandler(endpoints genendpoint.{{.Service.ServiceName}}Endpoints) http.Handler {
	m := http.NewServeMux()
	registerHTTPServeMuxRoutes(m, endpoints)
	return m
}

// RegisterHTTPRoutes binds the generated HTTP routes onto a standard ServeMux.
func RegisterHTTPRoutes(router *http.ServeMux, endpoints genendpoint.{{.Service.ServiceName}}Endpoints, prefix string) {
{{range .UnaryMethods}}
	// {{.HTTPMethod}} {{.Route}}
	router.Handle("{{.HTTPMethod | upper}} "+routePath(prefix, "{{.Route}}"), server.NewServer(
		endpoints.{{.Name}}Endpoint,
		decode{{.Name}}Request,
		encode{{.Name}}Response,
		server.ServerErrorEncoder(server.JSONErrorEncoder),
	))
{{end}}
}

func registerHTTPServeMuxRoutes(m *http.ServeMux, endpoints genendpoint.{{.Service.ServiceName}}Endpoints) {
{{range .UnaryMethods}}
	m.Handle("{{.HTTPMethod | upper}} {{.Route}}", server.NewServer(
		endpoints.{{.Name}}Endpoint,
		decode{{.Name}}Request,
		encode{{.Name}}Response,
		server.ServerErrorEncoder(server.JSONErrorEncoder),
	))
{{end}}
}

func routePath(prefix, route string) string {
	if prefix == "" {
		return route
	}
	return prefix + route
}

{{range .UnaryMethods}}
// decode{{.Name}}Request uses the generated method-aware decode path.
//
// @Summary      {{.Summary}}
// @Description  {{if .Description}}{{.Description}}{{else}}{{.Name}} microservice endpoint{{end}}
// @Tags         {{$.Service.ServiceName}}
{{- if eq (.HTTPMethod | lower) "get"}}
// @Accept       json
// @Produce      json
// @Param        request  query     idl.{{.InputName}}  true  "{{.Name}} request"
{{- else}}
// @Accept       json
// @Produce      json
// @Param        request  body      idl.{{.InputName}}  true  "{{.Name}} request"
{{- end}}
// @Success      200      {object}  idl.{{.OutputName}}
// @Failure      400      {object}  server.ErrorResponse
// @Failure      500      {object}  server.ErrorResponse
// @Router       {{$.RoutePrefix}}{{.Route}} [{{.HTTPMethod | lower}}]
func decode{{.Name}}Request(_ context.Context, r *http.Request) (any, error) {
	var req idl.{{.InputName}}
{{- if eq (.HTTPMethod | lower) "get"}}
	if err := transporthttp.DecodeQueryRequest(r, &req); err != nil {
		return nil, err
	}
{{- else}}
	if err := server.DecodeJSONBody(r, &req, server.StrictJSONDecodeOptions(server.DefaultMaxJSONBodyBytes)); err != nil {
		return nil, server.JSONDecodeError{Err: err}
	}
{{- end}}
	return req, nil
}

func encode{{.Name}}Response(ctx context.Context, w http.ResponseWriter, response any) error {
	return json.NewEncoder(w).Encode(response)
}
{{end}}
