func printBanner(logger *kitlog.Logger, httpAddr string{{if .WithGRPC}}, grpcAddr string{{end}}, withOpenAPI bool{{if .WithInteraction}}, withInteraction bool{{end}}) {
	logger.Sugar().Info("------------------------------------------------------------")
	logger.Sugar().Infof(" Service: {{range .Project.Services}}{{.Name}} {{end}}")
	logger.Sugar().Infof(" HTTP: http://localhost%s", httpAddr)
	if withOpenAPI {
		logger.Sugar().Infof(" OpenAPI: http://localhost%s/openapi.json", httpAddr)
		logger.Sugar().Infof(" JSON Schema: http://localhost%s/schema.json", httpAddr)
		logger.Sugar().Infof(" API UI: http://localhost%s/swagger/index.html", httpAddr)
	}
{{if .WithInteraction}}	if withInteraction {
		logger.Sugar().Infof(" MCP: http://localhost%s/mcp", httpAddr)
	}
{{end}}{{if .WithGRPC}}	logger.Sugar().Infof(" gRPC: %s", grpcAddr)
{{end}}	logger.Sugar().Info(" Press Ctrl+C to stop")
}

func printAllRoutes(logger *kitlog.Logger, routes []generatedRouteEntry) {
	logger.Sugar().Info("Registered Routes")
	for _, route := range routes {
		logger.Sugar().Infof("  %-7s %s", route.Method, route.Path)
	}
}

{{if .WithConfig}}func newConfiguredLogger(cfg config.LoggingConfig) (*kitlog.Logger, error) {
	encoding := strings.ToLower(strings.TrimSpace(cfg.Format))
	if encoding == "" {
		encoding = "json"
	}
	if encoding != "json" && encoding != "console" {
		return nil, fmt.Errorf("unsupported logging format %q", cfg.Format)
	}

	levelText := strings.ToLower(strings.TrimSpace(cfg.Level))
	if levelText == "" {
		levelText = "info"
	}
	var level zapcore.Level
	if err := level.UnmarshalText([]byte(levelText)); err != nil {
		return nil, fmt.Errorf("unsupported logging level %q: %w", cfg.Level, err)
	}

	zapConfig := zap.NewProductionConfig()
	if encoding == "console" {
		zapConfig = zap.NewDevelopmentConfig()
	}
	zapConfig.Encoding = encoding
	zapConfig.Level = zap.NewAtomicLevelAt(level)
	return zapConfig.Build()
}

{{end}}
func main() {
{{if .WithConfig}}	configPath := flag.String("config", "config/config.yaml", "path to config file")
	flag.CommandLine.Parse(filterArgs(os.Args[1:], "-config"))

	cfg, err := config.Load(*configPath)
	if err != nil {
		panic("FATAL: load config: " + err.Error())
	}

	var (
		httpAddr = flag.String("http.addr", cfg.Server.HTTPAddr, "HTTP listen address")
{{if .WithGRPC}}		grpcAddr = flag.String("grpc.addr", cfg.Server.GRPCAddr, "gRPC listen address")
{{end}}{{if .WithDB}}		dsn = flag.String("db.dsn", cfg.Database.DSN, "{{.DBDriver}} DSN")
		autoMigrate = flag.Bool("auto-migrate", cfg.Database.AutoMigrate, "run database AutoMigrate on startup")
{{end}}	)
	flag.Parse()
{{if .WithDB}}	cfg.Database.AutoMigrate = *autoMigrate
{{end}}

	logger, err := newConfiguredLogger(cfg.Logging)
	if err != nil {
		panic("FATAL: create logger: " + err.Error())
	}
	defer logger.Sync() //nolint:errcheck
	logger.Sugar().Infof("Config loaded from: %s", *configPath)
{{else}}	var (
		httpAddr = flag.String("http.addr", ":8080", "HTTP listen address")
{{if .WithGRPC}}		grpcAddr = flag.String("grpc.addr", ":8081", "gRPC listen address")
{{end}}{{if .WithDB}}		dsn = flag.String("db.dsn", "{{.DBDefaultDSN}}", "{{.DBDriver}} DSN")
		autoMigrate = flag.Bool("auto-migrate", false, "run database AutoMigrate on startup")
{{end}}	)
	flag.Parse()

	logger, _ := kitlog.NewDevelopment()
	defer logger.Sync() //nolint:errcheck
{{end}}

{{if .WithDB}}	db, err := gorm.Open({{.DBOpenCall}}, &gorm.Config{})
	if err != nil {
		logger.Sugar().Fatalf("FATAL: connect database failed: %v", err)
	}
	sqlDB, err := db.DB()
	if err != nil {
		logger.Sugar().Fatalf("FATAL: get database handle failed: %v", err)
	}
	defer sqlDB.Close() //nolint:errcheck
{{if .WithConfig}}	sqlDB.SetMaxOpenConns(cfg.Database.MaxOpenConns)
	sqlDB.SetMaxIdleConns(cfg.Database.MaxIdleConns)
	sqlDB.SetConnMaxLifetime(cfg.Database.ConnMaxLifetime)
{{else}}	sqlDB.SetMaxOpenConns(20)
	sqlDB.SetMaxIdleConns(5)
	sqlDB.SetConnMaxLifetime(time.Hour)
{{end}}
	logger.Sugar().Infof("DB connected [driver=%s dsn=%s]", "{{.DBDriver}}", redactDSN(*dsn))

	repoDB := repository.NewDB(db)
{{end}}

{{if .WithDB}}	generated := initGeneratedServices(logger{{if .WithConfig}}, cfg{{end}}, repoDB)
{{else}}	generated := initGeneratedServices(logger{{if .WithConfig}}, cfg{{end}})
{{end}}	runtime := generated.generatedRuntime()

{{if .WithInteraction}}	interactionRuntime := initInteractionRuntime(&generated)
{{end}}

{{if .WithDB}}	if {{if .WithConfig}}cfg.Database.AutoMigrate{{else}}*autoMigrate{{end}} {
		if err := runtime.autoMigrate(db); err != nil {
			logger.Sugar().Fatalf("FATAL: auto migrate failed: %v", err)
		}
		logger.Sugar().Info("DB migration done")
	} else {
		logger.Sugar().Info("DB migration skipped")
	}
{{end}}

	r := http.NewServeMux()
	healthHandler := func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "application/json")
		w.WriteHeader(http.StatusOK)
		fmt.Fprintln(w, `{"status":"ok","service":"{{range .Project.Services}}{{.Name}}{{end}}"}`)
	}
	r.HandleFunc("GET /health", healthHandler)
	r.HandleFunc("HEAD /health", healthHandler)

{{if .WithInteraction}}	mcpHandler := mcp.NewStreamableHandler(interactionRuntime)
	r.Handle("GET /mcp", mcpHandler)
	r.Handle("POST /mcp", mcpHandler)
	r.Handle("DELETE /mcp", mcpHandler)
{{end}}

{{if .WithOpenAPI}}	r.HandleFunc("GET /openapi.json", docs.Handler)
	r.HandleFunc("GET /schema.json", docs.SchemaHandler)
	r.Handle("GET /swagger/", swaggerUI.New("{{range .Project.Services}}{{.Name}} {{end}}API", "/openapi.json", "/swagger/"))
{{end}}

	runtime.registerRoutes(r)
{{if .WithConfig}}	customRoutes := registerCustomRoutes(r)
{{else}}	registerCustomRoutes(r)
{{end}}

{{if .WithConfig}}	if cfg.Debug.RoutesEnabled {
		r.HandleFunc("GET /debug/routes", func(w http.ResponseWriter, req *http.Request) {
		w.Header().Set("Content-Type", "application/json; charset=utf-8")
			_ = json.NewEncoder(w).Encode(generatedRouteEntries(runtime, customRoutes, {{if .WithOpenAPI}}true{{else}}false{{end}}, true{{if .WithInteraction}}, true{{end}}))
		})
	}
{{end}}

{{if .WithConfig}}	if cfg.Debug.PrintRoutes {
		allRoutes := generatedRouteEntries(runtime, customRoutes, {{if .WithOpenAPI}}true{{else}}false{{end}}, cfg.Debug.RoutesEnabled{{if .WithInteraction}}, true{{end}})
		printAllRoutes(logger, allRoutes)
	}
{{end}}

	httpServer := &http.Server{
		Addr:         *httpAddr,
		Handler: http.HandlerFunc(func(w http.ResponseWriter, req *http.Request) {
			start := time.Now()
			r.ServeHTTP(w, req)
			logger.Sugar().Infof("[HTTP] %s %s %v", req.Method, req.URL.Path, time.Since(start))
		}),
{{if .WithConfig}}		ReadTimeout:  cfg.Server.ReadTimeout,
		ReadHeaderTimeout: cfg.Server.ReadHeaderTimeout,
		WriteTimeout: cfg.Server.WriteTimeout,
{{else}}		ReadTimeout:       15 * time.Second,
		ReadHeaderTimeout: 5 * time.Second,
		WriteTimeout:      0,
{{end}}		IdleTimeout:  60 * time.Second,
	}
	serverErr := make(chan error, 2)
	httpListener, err := net.Listen("tcp", *httpAddr)
	if err != nil {
		logger.Sugar().Fatalf("FATAL: HTTP listen: %v", err)
	}
	defer httpListener.Close() //nolint:errcheck

{{if .WithGRPC}}	lis, err := net.Listen("tcp", *grpcAddr)
	if err != nil {
		logger.Sugar().Fatalf("FATAL: gRPC listen: %v", err)
	}
	defer lis.Close() //nolint:errcheck
	grpcServer := grpc.NewServer()
	runtime.registerGRPCServices(grpcServer)
{{end}}

	go func() {
		if err := httpServer.Serve(httpListener); err != nil && err != http.ErrServerClosed {
			serverErr <- fmt.Errorf("HTTP server: %w", err)
		}
	}()

{{if .WithGRPC}}
	go func() {
		if err := grpcServer.Serve(lis); err != nil && err != grpc.ErrServerStopped {
			serverErr <- fmt.Errorf("gRPC server: %w", err)
		}
	}()
{{end}}

	printBanner(logger, *httpAddr{{if .WithGRPC}}, *grpcAddr{{end}}, {{if .WithOpenAPI}}true{{else}}false{{end}}{{if .WithInteraction}}, true{{end}})

	runContext, stopSignals := signal.NotifyContext(context.Background(), syscall.SIGINT, syscall.SIGTERM)
	defer stopSignals()
	select {
	case <-runContext.Done():
		logger.Sugar().Info("Received shutdown signal")
	case err := <-serverErr:
		logger.Sugar().Errorf("Server stopped unexpectedly: %v", err)
	}
	logger.Sugar().Info("Shutting down...")

{{if .WithConfig}}	shutdownTimeout := cfg.Server.GracefulShutdownTimeout
	if shutdownTimeout <= 0 {
		shutdownTimeout = 30 * time.Second
	}
	ctx, cancel := context.WithTimeout(context.Background(), shutdownTimeout)
{{else}}	ctx, cancel := context.WithTimeout(context.Background(), 30*time.Second)
{{end}}	defer cancel()

	if err := httpServer.Shutdown(ctx); err != nil {
		logger.Sugar().Infof("HTTP shutdown error: %v", err)
	}
{{if .WithGRPC}}	grpcStopped := make(chan struct{})
	go func() {
		grpcServer.GracefulStop()
		close(grpcStopped)
	}()
	select {
	case <-grpcStopped:
		logger.Sugar().Info("gRPC stopped")
	case <-ctx.Done():
		grpcServer.Stop()
		logger.Sugar().Infof("gRPC graceful stop timed out: %v", ctx.Err())
	}
{{end}}	logger.Sugar().Info("Server exited cleanly")
}

{{- if .WithDB }}

func redactDSN(dsn string) string {
	if dsn == "" {
		return ""
	}
	return "<redacted>"
}

{{- end }}
{{- if .WithConfig }}

func filterArgs(args []string, name string) []string {
	var out []string
	for i := 0; i < len(args); i++ {
		arg := args[i]
		if arg == name || arg == "-"+strings.TrimPrefix(name, "-") {
			out = append(out, arg)
			if i+1 < len(args) {
				out = append(out, args[i+1])
				i++
			}
			continue
		}
		if strings.HasPrefix(arg, name+"=") || strings.HasPrefix(arg, "-"+strings.TrimPrefix(name, "-")+"=") {
			out = append(out, arg)
		}
	}
	return out
}
{{- end }}
